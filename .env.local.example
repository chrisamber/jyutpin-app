# Copy to .env.local (gitignored) or set these in the Vercel dashboard.

# Existing client-side vars (optional — app works without them)
VITE_GOOGLE_TTS_API_KEY=
VITE_YOUTUBE_API_KEY=AIzaSyBMFY51TezWZOy_ya2cqnGmEqGOFOW3aUA

# Server-side (used by /api/translate)
# Required: Claude Haiku translation calls
ANTHROPIC_API_KEY=

# Optional: Upstash Redis for shared translation cache.
# Without these the function still works — each unique line just hits Anthropic
# until the per-user localStorage cache fills in.
KV_REST_API_URL=
KV_REST_API_TOKEN=
